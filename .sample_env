# Este arquivo é apenas uma referência. O install.sh gera o .env automaticamente
# com caminhos absolutos baseados no diretório em que o repositório foi clonado.
CBM_CACHE_DIR=/caminho/absoluto/codebase-memory-mcp-server/cache
CBM_ALLOWED_ROOT=/caminho/absoluto/codebase-memory-mcp-server/repositories
CBM_MEM_BUDGET_MB=8192
CBM_HOST_BIN=/home/usuario/.local/bin/codebase-memory-mcp
LOCAL_UID=1000
LOCAL_GID=1000
UI_PORT=8080
ADMIN_EMAIL=joao@exemplo.com
ADMIN_USERNAME=joao@exemplo.com
OLLAMA_VERSION=0.32.1
OLLAMA_CHAT_MODEL=gemma4:e2b
COMPOSE_PROFILES=ollama-docker,monitoring
KNOWLEDGE_SYNC_FULL_RECONCILIATION_HOURS=168
KNOWLEDGE_SYNC_HTTP_RETRY_ATTEMPTS=3
PUBLIC_BASE_URL=http://localhost:8080
