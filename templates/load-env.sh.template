#!/usr/bin/env bash

ENV_FILE="@ENV_FILE@"

[[ -f "$ENV_FILE" ]] || { printf 'Arquivo não encontrado: %s\n' "$ENV_FILE" >&2; return 1 2>/dev/null || exit 1; }

set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a
export PATH="${HOME}/.local/bin:${PATH}"

printf 'Variáveis do Codebase Memory carregadas nesta sessão.\n'
